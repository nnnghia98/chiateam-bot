{
  "name": "chiateam-bot",
  "version": "1.2.0",
  "private": true,
  "main": "bot/index.js",
  "license": "MIT",
  "scripts": {
    "start": "node -r dotenv/config bot/index.js",
    "dev": "NODE_ENV=development DOTENV_CONFIG_PATH=.env.dev nodemon -r dotenv/config bot/index.js",
    "dev:prod": "NODE_ENV=production DOTENV_CONFIG_PATH=.env.production nodemon -r dotenv/config bot/index.js",
    "start:bot": "NODE_ENV=production node bot/index.js",
    "start:api": "node api/index.js",
    "dev:bot": "NODE_ENV=development DOTENV_CONFIG_PATH=.env.dev nodemon -r dotenv/config bot/index.js",
    "dev:api": "NODE_ENV=development DOTENV_CONFIG_PATH=.env.dev nodemon -r dotenv/config api/index.js",
    "dev:web": "cd web && yarn dev",
    "dev:admin": "cd admin && yarn dev",
    "build:admin": "cd admin && yarn build",
    "start:admin": "cd admin && yarn start",
    "init-db": "node api/db/init-database.js",
    "drop-db": "node api/db/drop-database.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.65.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.0.0"
  }
}
