{
  "name": "chiateam-bot",
  "version": "1.2.0",
  "private": true,
  "main": "bot/index.js",
  "license": "MIT",
  "scripts": {
    "start": "yarn start:bot",
    "start:bot": "NODE_ENV=production ENV_FILE=.env.production node bot/index.js",
    "start:api": "NODE_ENV=production ENV_FILE=.env.production node api/index.js",
    "start:admin": "cd admin && yarn start",
    "start:production": "yarn start:bot",
    "dev": "yarn dev:bot",
    "dev:bot": "NODE_ENV=development ENV_FILE=.env.local nodemon bot/index.js",
    "dev:api": "NODE_ENV=development ENV_FILE=.env.local nodemon api/index.js",
    "dev:admin": "cd admin && yarn dev",
    "docker:dev:up": "docker compose --env-file .env.local -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose --env-file .env.local -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env.local -f docker-compose.dev.yml logs -f --tail=200",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.yml up -d",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.yml down",
    "build:admin": "cd admin && yarn build",
    "init-db": "node api/db/init-database.js",
    "drop-db": "node api/db/drop-database.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.65.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.0.0"
  }
}
