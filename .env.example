# Environment File Identifier (for logging which env file is loaded)
ENV_FILE=.env

# Telegram Bot Configuration
BOT_OWNER_ID=your_bot_owner_id_here
BOT_ADMIN_IDS=your_bot_admin_1_id_here,your_bot_admin_2_id_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat & Thread Configuration
# Development
CHAT_ID=your_chat_id_here
DEFAULT_THREAD_ID= # leave blank if you want to send to default channel
MAIN_THREAD_ID=your_thread_id_here
ANNOUNCEMENT_THREAD_ID=your_thread_id_here
VIP_THREAD_ID=your_thread_id_here
STATISTICS_THREAD_ID=your_thread_id_here

# Production (uncomment when deploying to production)
# CHAT_ID=your_production_chat_id_here
# DEFAULT_THREAD_ID=1
# MAIN_THREAD_ID=your_production_main_thread_id
# ANNOUNCEMENT_THREAD_ID=your_production_announcement_thread_id
# VIP_THREAD_ID=your_production_vip_thread_id
# STATISTICS_THREAD_ID=your_production_statistics_thread_id

# Database Configuration (Legacy)
DATABASE_NAME=your_database_name
DB_DIR="./src"

# Web UI Configuration
WEB_UI_TOKEN=your_web_ui_token_here
WEB_API_PORT=4000
WEB_UI_ORIGIN=http://localhost:5173

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Web UI (Vercel URL — used for CORS)
WEB_UI_URL=https://your-vercel-app.vercel.app

# Admin UI (Railway URL — used for CORS)
ADMIN_UI_URL=https://your-admin-app.up.railway.app
# For local dev: http://localhost:8389
