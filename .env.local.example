# Environment File Identifier (for logging/debugging)
ENV_FILE=.env.local

# Telegram Bot Configuration
BOT_OWNER_ID=your_bot_owner_id_here
BOT_ADMIN_IDS=your_bot_admin_1_id_here,your_bot_admin_2_id_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Local Chat & Thread Configuration
CHAT_ID=your_chat_id_here
DEFAULT_THREAD_ID=
MAIN_THREAD_ID=your_thread_id_here
ANNOUNCEMENT_THREAD_ID=your_thread_id_here
VIP_THREAD_ID=your_thread_id_here
STATISTICS_THREAD_ID=your_thread_id_here

# API / runtime configuration
API_PORT=8787
BOT_STATE_FILE=.runtime/bot/storage.json
INTERNAL_API_AUTH_TOKEN=change-this-shared-internal-token
BOT_API_BASE_URL=http://127.0.0.1:8787

# Database (external)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Optional UI origins for CORS
ADMIN_UI_URL=http://localhost:8389

# Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
