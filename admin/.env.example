# API configuration for the server-side proxy
# This can be a private hostname or any API URL reachable by the admin server.
API_INTERNAL_URL=http://chiateam-api.railway.internal:8787

# Shared secret between the admin proxy and the API service
INTERNAL_API_AUTH_TOKEN=change-this-shared-internal-token

# Session and login credentials (server-only)
ADMIN_SESSION_SECRET=change-this-session-secret
ADMIN_PASSWORD=admin123
VIEWER_PASSWORD=viewer123
